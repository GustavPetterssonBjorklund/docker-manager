{
	"productName": "Docker Manager",
	"version": "0.1.0",
	"identifier": "com.gustav.docker-manager",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"beforeBuildCommand": "pnpm build",
		"devUrl": "http://localhost:5173",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "Docker Manager",
				"width": 520,
				"height": 920,
				"resizable": true
			}
		],
		"security": {
			"csp": null,
			"capabilities": ["main-capability"]
		}
	},
	"bundle": {
		"active": true,
		"targets": "all"
	}
}
